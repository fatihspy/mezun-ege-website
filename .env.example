# Bu dosyayı kopyalayarak .env oluştur: cp .env.example .env
# Gerçek değerleri .env'e yaz, bu dosyayı boş bırak

PORT=3000

# MongoDB Atlas bağlantısı (production)
# Örn: mongodb+srv://kullanici:sifre@cluster.mongodb.net/mezun_ege
MONGODB_URI=mongodb://127.0.0.1:27017/mezun_egew

# JWT — production'da güçlü rastgele string kullan:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=BURAYA_GUCLU_RASTGELE_STRING_YAZ
JWT_EXPIRES_IN=1d
JWT_EXPIRES_IN_HATIRLA=3650d

# Gmail SMTP — production'da App Password kullan
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Egemyo Mezun <noreply@egemyo.ege.edu.tr>

# Okul mail domaini
OKUL_MAIL_DOMAIN=ogrenci.ege.edu.tr

# Production'da kendi domain'ini yaz: https://egemyo.ege.edu.tr
ALLOWED_ORIGIN=*

# Node ortamı: development | production
NODE_ENV=development

# Test env (npm test / npm run test:login / npm run test:register)
TEST_API_BASE_URL=http://localhost:3000
TEST_EMAIL=
TEST_PASSWORD=
TEST_REGISTER_EMAIL=
TEST_REGISTER_PASSWORD=
TEST_REGISTER_ROLE=isveren
